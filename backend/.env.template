# DataBridgeAI Cognee Backend — Environment Variables
# Copy to .env for local development. On Cloud Run, use --set-secrets and --set-env-vars.

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=your-anthropic-api-key

# Embedding Configuration
# Anthropic does not provide embeddings; OpenAI text-embedding-3-large is the standard choice
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_API_KEY=your-openai-api-key

# Graph Store
GRAPH_DATABASE_PROVIDER=networkx

# Cognee Settings
REQUIRE_AUTHENTICATION=false
LOG_LEVEL=INFO

# Port (Cloud Run injects this; default 8000 for local)
PORT=8000
